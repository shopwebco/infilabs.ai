# ─────────────────────────────────────────────────────────────
# Xenon environment variables
# Copy to `.env` (gitignored) and fill in. Never commit real secrets.
# Missing keys fail loudly at startup/feature-gate — never a silent fake fallback.
# ─────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres) ──────────────────────────────
# DATABASE_URL: pooled connection (PgBouncer, port 6543) — used by the app at runtime.
#   Supabase → Project Settings → Database → Connection string → "Transaction" pooler.
#   Append ?pgbouncer=true&connection_limit=1 for serverless (Vercel) runtimes.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL: direct connection (port 5432) — used by Prisma Migrate / introspection only.
#   Supabase → same page → "Session" / direct connection string.
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ── Auth.js (NextAuth v5) ─────────────────────────────────────
# Generate with: openssl rand -base64 32   (or `npx auth secret`)
AUTH_SECRET=""
# Optional Google OAuth (leave blank to disable the Google button)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Stripe (Phase 1) — test-mode keys are real, use them in dev ─
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Stripe Price IDs (create the products/prices in the Stripe dashboard, test mode).
STRIPE_PRICE_PRO=""            # Pro $49/mo recurring price id (price_...)
STRIPE_PRICE_AGENCY=""         # Agency $199/mo base price id
STRIPE_PRICE_AGENCY_CLIENT=""  # +$25/mo per extra client project (quantity item)
# Webhook secret for CONNECTED-ACCOUNT events ("Listen to events on connected accounts")
STRIPE_CONNECT_WEBHOOK_SECRET=""

# ── Anthropic (Phase 2) ───────────────────────────────────────
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ── Email (Phase 4) — Resend or SMTP ──────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Xenon <no-reply@example.com>"

# ── App ───────────────────────────────────────────────────────
# Public base URL of this deployment (Vercel provides VERCEL_URL; set APP_URL explicitly for prod domains)
APP_URL="http://localhost:3000"

# ── Amazon SP-API / Login with Amazon (Phase 8) — feature-gated if absent ─
AMAZON_LWA_CLIENT_ID=""
AMAZON_LWA_CLIENT_SECRET=""
AMAZON_SP_APP_ID=""                                # Seller Central app id (amzn1.sp.solution....)
AMAZON_SP_ENDPOINT="https://sellingpartnerapi-na.amazon.com"  # region endpoint
AMAZON_MARKETPLACE_IDS="ATVPDKIKX0DER"             # comma-separated marketplace ids (US default)

# ── Platform config ───────────────────────────────────────────
# Optional Stripe Connect application fee percent (0 = none)
PLATFORM_FEE_PERCENT="0"

# ── Scheduled jobs (Phase 7 briefings) ────────────────────────
# Shared secret for the cron endpoint. Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>`; manual triggers can use x-cron-secret.
CRON_SECRET=""
